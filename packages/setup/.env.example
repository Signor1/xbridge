# ============================================================
# XBridge Setup — Environment Configuration
# ============================================================

# Network: testnet or mainnet
XBRIDGE_ENV=testnet

# Door accounts (generated by 01-fund-doors.ts, or provide your own)
XAHAU_DOOR_SEED=
XAHAU_DOOR_ADDRESS=
XRPL_DOOR_SEED=
XRPL_DOOR_ADDRESS=

# Bridge token configuration
# For native XAH/XRP bridging, leave BRIDGE_CURRENCY as "XRP" and BRIDGE_ISSUER empty
# For IOU bridging (e.g., AXK), set both currency and issuer
BRIDGE_CURRENCY=XRP
BRIDGE_ISSUER=

# Witness accounts (generated by 01-fund-doors.ts, or provide your own)
# Each witness needs an account on BOTH chains
WITNESS_1_SEED=
WITNESS_1_XAHAU_ADDRESS=
WITNESS_1_XRPL_ADDRESS=

WITNESS_2_SEED=
WITNESS_2_XAHAU_ADDRESS=
WITNESS_2_XRPL_ADDRESS=

WITNESS_3_SEED=
WITNESS_3_XAHAU_ADDRESS=
WITNESS_3_XRPL_ADDRESS=

# Quorum — how many witnesses must agree
BRIDGE_QUORUM=2
