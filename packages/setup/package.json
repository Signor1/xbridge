{
  "name": "@xbridge/setup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fund": "ts-node --transpile-only scripts/01-fund-accounts.ts",
    "signers": "ts-node --transpile-only scripts/02-set-signer-list.ts",
    "disable-master": "ts-node --transpile-only scripts/03-disable-master.ts",
    "verify": "ts-node --transpile-only scripts/04-verify.ts",
    "save-config": "ts-node --transpile-only scripts/05-save-config.ts",
    "setup-all": "ts-node --transpile-only scripts/01-fund-accounts.ts && ts-node --transpile-only scripts/02-set-signer-list.ts && ts-node --transpile-only scripts/04-verify.ts && ts-node --transpile-only scripts/05-save-config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "xrpl": "^4.6.0",
    "@xbridge/config": "workspace:*",
    "dotenv": "^17.2.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
