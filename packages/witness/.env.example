# XBridge Witness

XBRIDGE_ENV=testnet
WITNESS_NAME=witness-1
WITNESS_SEED=
PORT=3001

# Door accounts
XAHAU_DOOR_ADDRESS=
XRPL_DOOR_ADDRESS=

# Bridge quorum
BRIDGE_QUORUM=2

# Peer witness URLs (other witnesses this one talks to)
PEER_1_URL=http://localhost:3002
PEER_2_URL=http://localhost:3003

# SQLite path
WITNESS_DB_PATH=./data/witness-1.db
