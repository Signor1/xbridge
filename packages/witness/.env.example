# ============================================================
# XBridge Witness — Environment Configuration
# ============================================================

# Network: testnet or mainnet
XBRIDGE_ENV=testnet

# Witness identity
WITNESS_NAME=witness-1
WITNESS_SEED=

# Door accounts (from setup)
XAHAU_DOOR_ADDRESS=
XRPL_DOOR_ADDRESS=

# Bridge token (must match what was set during bridge creation)
BRIDGE_CURRENCY=XRP
BRIDGE_ISSUER=

# Health check port
HEALTH_PORT=3000

# SQLite database path
WITNESS_DB_PATH=./witness.db

# Retry config
MAX_ATTESTATION_RETRIES=3
RETRY_DELAY_MS=5000
